{
  "routes": [
    {
      "id": "r-raft",
      "enabled": true,
      "match": {
        "hosts": ["raft.localtest.me"],
        "path": { "type": "prefix", "value": "/" }
      },
      "upstream_pool": "pool-raft"
    }
  ],
  "upstream_pools": {
    "pool-raft": {
      "upstreams": [
        "backend-a:8080",
        "backend-b:8080",
        "backend-c:8080"
      ],
      "health_check": {
        "path": "/health",
        "interval": "5s",
        "timeout": "2s",
        "expect_status": 200
      }
    }
  }
}
